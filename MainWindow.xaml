<Window x:Class="PolygonApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PolygonApp"
        Title="Polygon Drawer"
        Width="800" Height="500"
        ResizeMode="NoResize"
        Background="White">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <local:NullToVisConverter x:Key="NullToVis"/>

        <Style TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#222222"/>
            <Setter Property="BorderBrush"      Value="#888888"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush"     Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="4,3"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#222222"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#222222"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderBrush"     Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="Transparent"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Style.Triggers>
                <Trigger Property="IsSelected"   Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#222222"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: fixed-size preview canvas (360 × 460) -->
        <Border Grid.Column="0" Margin="16" BorderBrush="#BBBBBB" BorderThickness="1" Background="White">
            <Canvas Width="360" Height="460" ClipToBounds="True">
                <Polygon Points="{Binding PreviewPoints}"
                         Stroke="Black" StrokeThickness="1.5"
                         Visibility="{Binding PreviewPoints, Converter={StaticResource NullToVis}}">
                    <Polygon.Fill>
                        <SolidColorBrush Color="{Binding SelectedPolygon.Color}"/>
                    </Polygon.Fill>
                </Polygon>
                <TextBlock Text="{Binding PreviewLabel}"
                           Canvas.Left="155" Canvas.Top="8"
                           FontSize="13" Foreground="DimGray"/>
            </Canvas>
        </Border>

        <!-- RIGHT panel -->
        <Border Grid.Column="1" BorderBrush="#BBBBBB" BorderThickness="1,0,0,0">
            <DockPanel Margin="10">

                <!-- Add form -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="Add polygon" FontWeight="Bold" Margin="0,0,0,8"/>

                    <TextBlock Text="Sides:" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding NewSides, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <TextBlock Text="Color (#RRGGBB):" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding NewColor, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <Button Content="Add" Command="{Binding AddCommand}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Margin="0,0,0,10" Background="#BBBBBB"/>

                <!-- Selected info -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10"
                            Visibility="{Binding SelectedPolygon, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="Selected:" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBlock FontSize="11">
                        <Run Text="Sides: "/><Run Text="{Binding SelectedPolygon.Sides}"/>
                    </TextBlock>
                    <TextBlock FontSize="11">
                        <Run Text="Color: "/><Run Text="{Binding SelectedPolygon.Color}"/>
                    </TextBlock>
                    <TextBlock Text="New color:" FontSize="11" Margin="0,6,0,2"/>
                    <TextBox FontSize="11" Margin="0,0,0,4"
                             Text="{Binding ChangeColor, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Change color" Command="{Binding ChangeColorCommand}"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Margin="0,0,0,8" Background="#BBBBBB"/>

                <TextBlock DockPanel.Dock="Top" Text="Saved polygons"
                           FontWeight="Bold" Margin="0,0,0,6"/>

                <ListBox ItemsSource="{Binding Polygons}"
                         SelectedItem="{Binding SelectedPolygon}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="12" Padding="2">
                                <Run Text="{Binding Sides}"/>
                                <Run Text=" sides — "/>
                                <Run Text="{Binding Color}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>
    </Grid>
</Window>
